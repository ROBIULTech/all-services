rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "shasultan2003@gmail.com" || 
        request.auth.token.email == "secure.node.admin@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email_verified == true && request.auth.token.email.matches('.*@admin.com')
      );
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Collection Rules ---

    // User profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if true;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Global settings
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Products
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Orders
    match /orders/{orderId} {
      allow get, list, create: if true; 
      allow update, delete: if true; // Temporarily unblocked to allow admin actions
    }

    // Trash
    match /trash/{trashId} {
      allow read, write: if true;
    }

    // Sessions - Vital for auditing
    match /sessions/{sessionId} {
      allow get: if true; // Allow checking session status by ID
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update: if true; // App logic needs this for session heartbeat/tracking
      allow delete: if isAdmin();
    }

    // Login History
    match /login_history/{historyId} {
      allow list: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if true;
    }

    // Archived Users
    match /archived_users/{docId} {
      allow read, write: if isAdmin();
    }

    // Test connection
    match /test/{docId} {
      allow read, write: if true;
    }
  }
}
